<?xml version="1.0" encoding="utf-8"?>
<!-- Chocolatey package for the PushPatch CLI (Windows). -->
<package xmlns="http://schemas.microsoft.com/packaging/2015/06/nuspec.xsd">
  <metadata>
    <id>pushpatch</id>
    <version>0.1.0</version>
    <title>PushPatch CLI</title>
    <authors>PushPatch</authors>
    <projectUrl>https://pushpatch.in</projectUrl>
    <packageSourceUrl>https://github.com/pushpatch/pushpatch_cli</packageSourceUrl>
    <licenseUrl>https://github.com/pushpatch/pushpatch_cli/blob/main/LICENSE</licenseUrl>
    <requireLicenseAcceptance>false</requireLicenseAcceptance>
    <tags>flutter ota updates shorebird cli pushpatch</tags>
    <summary>Self-hostable OTA update management CLI for Flutter apps</summary>
    <description>
      PushPatch is a CLI for managing over-the-air (OTA) updates for Flutter
      apps — releases, patches, staged rollouts, channels and rollback —
      against a self-hosted PushPatch server.
    </description>
  </metadata>
  <files>
    <file src="tools\**" target="tools" />
  </files>
</package>
